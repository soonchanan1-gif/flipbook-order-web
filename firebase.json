{
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": [
    {
      "bucket": "fifty-page-order-458df.firebasestorage.app",
      "rules": "storage.rules"
    }
  ],
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/order",
        "destination": "/order.html"
      },
      {
        "source": "/**",
        "destination": "/download.html"
      }
    ]
  }
}
